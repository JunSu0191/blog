DB_URL=jdbc:mysql://localhost:3306/blog?useSSL=false&useUnicode=true&serverTimezone=Asia/Seoul
DB_USERNAME=blog
DB_PASSWORD=change-me

JWT_SECRET=change-this-jwt-secret-at-least-32-bytes
JWT_EXPIRATION_MS=3600000

# Optional test overrides
TEST_DB_URL=
TEST_DB_USERNAME=
TEST_DB_PASSWORD=
TEST_JWT_SECRET=
TEST_JWT_EXPIRATION_MS=

APP_PUBLIC_BASE_URL=http://localhost:8080
APP_WEB_BASE_URL=http://localhost:5173
APP_API_BASE_URL=http://localhost:8080
APP_UPLOAD_PUBLIC_BASE_URL=http://localhost:8080/upload
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://192.168.*.*:5173,http://10.*.*.*:5173,http://172.*.*.*:5173
APP_AUTH_ALLOW_DEV_FALLBACK=false
APP_AUTH_DEV_USER_ID=1
APP_AUTH_RESET_TOKEN_EXPIRE_SECONDS=900
APP_AUTH_RESET_TOKEN_HASH_SECRET=change-this-reset-token-secret

APP_ADMIN_SEED_ENABLED=false
APP_ADMIN_USERNAME=
APP_ADMIN_PASSWORD=
APP_ADMIN_NAME=
APP_ADMIN_SEED_DISALLOWED_PASSWORD=
APP_ADMIN_MUST_CHANGE_PASSWORD=true

# Optional blog category seed
APP_CATEGORY_SEED_ENABLED=false
APP_CATEGORY_SEED_OVERWRITE_EXISTING=false

# Optional blog content seed (author + tags + posts)
APP_BLOG_SEED_ENABLED=false
APP_BLOG_SEED_OVERWRITE_EXISTING=false
APP_BLOG_SEED_AUTHOR_USERNAME=seed_writer
APP_BLOG_SEED_AUTHOR_PASSWORD=

APP_OAUTH2_GOOGLE_CLIENT_ID=replace-with-google-client-id
APP_OAUTH2_GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
APP_OAUTH2_KAKAO_CLIENT_ID=replace-with-kakao-client-id
APP_OAUTH2_KAKAO_CLIENT_SECRET=replace-with-kakao-client-secret
APP_OAUTH2_NAVER_CLIENT_ID=replace-with-naver-client-id
APP_OAUTH2_NAVER_CLIENT_SECRET=replace-with-naver-client-secret
APP_OAUTH2_SUCCESS_REDIRECT_URI=http://localhost:5173/auth/callback
APP_OAUTH2_FAILURE_REDIRECT_URI=http://localhost:5173/auth/callback

APP_VERIFICATION_CODE_EXPIRE_SECONDS=300
APP_VERIFICATION_MAX_ATTEMPTS=5
APP_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
APP_VERIFICATION_IP_RATE_LIMIT_PER_MINUTE=30
APP_VERIFICATION_HASH_SECRET=change-this-verification-hash-secret
APP_VERIFICATION_MOCK_EXPOSE_CODE=false

# Optional: INFO(default) / DEBUG
APP_LOG_LEVEL_FLYWAY=INFO
